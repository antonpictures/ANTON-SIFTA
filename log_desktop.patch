+# UTILITY: find parent QMdiSubWindow and close it
+# ──────────────────────────────────────────────────────────────
+
+def close_parent_subwindow(widget):
+    p = widget.parent()
+    while p is not None and not isinstance(p, QMdiSubWindow):
+        p = p.parent()
+    if p:
+        p.close()
