## Reference sketch — `SwarmDreamEngine` (DIRT — not merged)

*Aligned to real ledger field `td_value`. For pytest / smoke only until hooked behind GO + backup policy.*

```python
#!/usr/bin/env python3
"""Reference only — see tournament ALICE §11."""
import json
import os
from pathlib import Path


class SwarmDreamEngine:
    def __init__(self, state_dir: Path | None = None):
        self.state_dir = state_dir or Path(".sifta_state")
        self.short_term_ledger = self.state_dir / "body_brain_memory.jsonl"
        self.long_term_engrams = self.state_dir / "long_term_engrams.jsonl"

    def _hippocampal_replay(self, traces: list) -> str:
        best_action = None
        highest = float("-inf")
        for trace in traces:
            val = float(trace.get("td_value", trace.get("value", 0.0)))
            act = trace.get("action") or {}
            if val > highest:
                highest = val
                best_action = act
        return (
            f"Under recorded pressures, action {best_action!r} "
            f"carried highest td_value={highest}."
        )

    def trigger_rem_sleep(self) -> None:
        if not self.short_term_ledger.exists():
            return
        traces: list = []
        with open(self.short_term_ledger, "r", encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    traces.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
        if not traces:
            return
        engram = self._hippocampal_replay(traces)
        self.long_term_engrams.parent.mkdir(parents=True, exist_ok=True)
        with open(self.long_term_engrams, "a", encoding="utf-8") as f:
            f.write(json.dumps({"type": "engram", "content": engram}, ensure_ascii=False) + "\n")
        # PRODUCTION REQUIRES: signed backup + retention policy + Architect GO
        os.remove(self.short_term_ledger)
```

