*.eggs/
.venv/
.venv-*/
venv/
env/
.matplotlib_cache/
build/
node_modules/
**/node_modules/
# dist/ holds the .app bundle binary — track only manifest text, not blobs
/dist/SIFTA.app/
/dist/**/*.dylib
/dist/**/*.so


# ── SIFTA runtime state — NEVER track (the body's nervous system) ──────
# These directories hold continuous append-only ledgers, embeddings,
# audio frames, vision frames, voice transcripts, hardware probes —
# all hardware-bound, personal, and regenerable. The species DNA
# (code + doctrine) lives in the tracked tree; the individual organism
# lives in these directories on this M5 silicon.
.sifta_state/
.sifta_trash/
.sifta_directives/
.sifta_documents/
.sifta_quarantine/
.sifta_reputation/
.sifta_votes/
.sifta/
**/.sifta_state/


