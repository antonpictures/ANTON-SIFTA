# ── Python ────────────────────────────────────────────────────────────────────
*.pyc
*.pyo
__pycache__/
*.egg-info/
dist/
build/
.venv/
venv/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── SIFTA Runtime State (never version swarm runtime) ────────────────────────
# Agent JSON state is managed by the swarm; commit only intentional snapshots.
# Committed state (node_pki_registry.json, genesis_log.jsonl) tracked explicitly.
.sifta_state/*.json
!.sifta_state/node_pki_registry.json

# Ledger files — single-writer truth, not versioned per-machine
repair_log.jsonl
STGM_TX_LOG.jsonl
hermes_stdout.log
m5queen_dead_drop.jsonl

# Session / trace logs
decision_trace.log
watcher_metrics.jsonl
sifta_session_log/
*.log

# Locked files
*.lock
.sifta_state/*.lock

# Migration artifacts
.sifta_state/*_MIGRATED.json
.sifta_state/migration_log.jsonl

# Binary / DB
*.db
*.sqlite

# ── Cryptographic Key Material (NEVER commit private keys) ───────────────────
~/.sifta/
~/.sifta_keys/
*.pem
*.key
!*.pub.pem

# ── Dead storage ──────────────────────────────────────────────────────────────
.sifta/
.sifta_cemetery/
.sifta_reputation/
.sifta_votes/
bureau_of_identity/
pheromone_archive/
scripts/legacy/

# ── Docs noise (internal working docs, not architecture) ─────────────────────
docs/imperial_daily/
docs/ALICE_PHASE*
docs/M1THER_*
docs/MAC_MINI_*
docs/PHASE_5_*
docs/TOMORROW_*
docs/WALLET_*
docs/LIVE_DIRECTOR_*
docs/00_ALICE_*
docs/selling_*
docs/veo3_*
docs/wormhole_*

# ── Dev/test noise ────────────────────────────────────────────────────────────
test_environment/benchmark_100/
test_environment/requests_broken/
benchmark_results.py
cron_backup.txt
static/

# ── WhatsApp Bridge runtime ───────────────────────────────────────────────────
whatsapp_bridge/whatsapp_session/
whatsapp_bridge/node_modules/
wormhole.log

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
CEMETERY/
logs/
