PART E — HARDENED proof_of_property() (drop-in replacement)
═══════════════════════════════════════════════════════════════════════

The function below tests EVERY property listed in PART B as an
assertion, including the load-bearing minimum-KL theorem. If this
runs cleanly the implementation is verified to do what it claims.

If any future change to swarm_maximum_caliber.py breaks the math,
this proof will catch it.
"""
import sys
sys.path.insert(0, "/Users/ioanganton/Music/ANTON_SIFTA/System")
import numpy as np
from swarm_maximum_caliber import SwarmMaximumCaliber


def _stationary(P, iters=2000):
    n = P.shape[0]
    pi = np.ones(n) / n
    for _ in range(iters):
        pi = pi @ P
        pi /= pi.sum()
    return pi


def _flux(P, A, pi=None):
    if pi is None:
        pi = _stationary(P)
    return float(np.sum(pi[:, None] * P * A))


def _path_KL_vs_W0(P, W_0, pi=None):
    if pi is None:
        pi = _stationary(P)
    P_0 = W_0 / W_0.sum(axis=1)[:, None]
    D = 0.0
    for i in range(P.shape[0]):
        for j in range(P.shape[1]):
            if P[i, j] > 1e-15 and P_0[i, j] > 1e-15:
                D += pi[i] * P[i, j] * np.log(P[i, j] / P_0[i, j])
    return D


def proof_of_property():
    print("\n=== SIFTA MAXIMUM CALIBER : HARDENED PEER REVIEW ===")

    np.random.seed(42)
    mc = SwarmMaximumCaliber(num_states=5)
    P_0 = mc.W_0 / mc.W_0.sum(axis=1)[:, None]
    base_flux = _flux(P_0, mc.A)
    target = base_flux * 1.5

    P_ship = mc.compute_maxcal_transition_matrix(target)
    pi_ship = _stationary(P_ship)
    f_ship = _flux(P_ship, mc.A, pi_ship)
    D_ship = _path_KL_vs_W0(P_ship, mc.W_0, pi_ship)
    print(f"\n[1] Base flux            = {base_flux:.6f}")
    print(f"[2] Target flux          = {target:.6f}")
    print(f"[3] Achieved flux        = {f_ship:.6f}")
    print(f"[4] Constraint residual  = {f_ship - target:+.2e}")
    print(f"[5] KL(P_ship || P_0)    = {D_ship:.6f} nats/step")

    # Assertion 1: stochastic matrix sanity
    assert np.allclose(P_ship.sum(axis=1), 1.0), \
        "[FAIL] P_ship is not row-stochastic."
    assert (P_ship >= -1e-12).all(), \
        "[FAIL] P_ship has negative entries."

    # Assertion 2: constraint met to high precision
    assert abs(f_ship - target) / abs(target) < 1e-6, \
        f"[FAIL] Constraint not met tightly enough: residual = {f_ship-target:+.4e}"

    # Assertion 3: matrix actually changed under the constraint (non-trivial)
    assert np.max(np.abs(P_ship - P_0)) > 0.05, \
        "[FAIL] Constraint did not measurably reshape the matrix."

    # Assertion 4: LOAD-BEARING — minimum-KL among constraint-satisfying alternatives
    # Sample 30 alternatives within 1e-3 of the target flux. None should beat KL_ship.
    print("\n[6] Sampling 30 alternative constraint-satisfying matrices...")
    np.random.seed(2026)
    KLs = []
    attempts = 0
    while len(KLs) < 30 and attempts < 50000:
        attempts += 1
        P_alt = np.zeros_like(P_0)
        for i in range(P_0.shape[0]):
            alpha = np.maximum(P_ship[i] * 50.0, 1e-3)
            P_alt[i] = np.random.dirichlet(alpha)
        np.fill_diagonal(P_alt, 0.0)
        rs = P_alt.sum(axis=1)
        if (rs == 0).any():
            continue
        P_alt = P_alt / rs[:, None]
        f = _flux(P_alt, mc.A)
        if abs(f - target) / abs(target) < 1e-3:
            KLs.append(_path_KL_vs_W0(P_alt, mc.W_0))
    print(f"    Found {len(KLs)} alts in {attempts} tries.")
    print(f"    alt KL: min={min(KLs):.6f}  median={np.median(KLs):.6f}  "
          f"max={max(KLs):.6f}")
    print(f"    ship KL: {D_ship:.6f}")

    below_ship = sum(1 for kl in KLs if kl < D_ship - 1e-6)
    assert below_ship == 0, (
        f"[FAIL] {below_ship}/{len(KLs)} alternatives have lower KL than shipped "
        f"MaxCal solution. The minimum-KL theorem is violated.")

    # Assertion 5: pre-renormalization construction is exact (Doob h-transform sanity)
    from scipy.optimize import root_scalar
    lam = root_scalar(mc._constraint_error, args=(target,),
                      bracket=[-10, 10], method='brentq').root
    M = mc.W_0 * np.exp(-lam * mc.A)
    eigvals, V = np.linalg.eig(M)
    idx = int(np.argmax(eigvals.real))
    mu = eigvals[idx].real
    v = np.abs(V[:, idx].real)
    P_pre = (M * v[None, :]) / (mu * v[:, None])
    pre_residual = abs(P_pre.sum(axis=1) - 1.0).max()
    print(f"\n[7] Pre-renormalization row-sum residual: {pre_residual:.2e}")
    assert pre_residual < 1e-10, (
        f"[FAIL] Doob-h-transform construction does not produce stochastic "
        f"matrix to machine precision. Eigenvector handling is wrong.")

    # Assertion 6: Perron-Frobenius prerequisites
    assert (M >= -1e-12).all(), \
        "[FAIL] Tilted matrix M has negative entries — Perron-Frobenius doesn't apply."
    spectral_gap = (mu - sorted(np.abs(eigvals))[-2]) / mu
    print(f"[8] Spectral gap (μ - |λ_2|)/μ = {spectral_gap:.4f}")
    assert spectral_gap > 0.1, \
        f"[FAIL] Insufficient spectral gap ({spectral_gap:.4f}); Perron mode ambiguous."

    print("\n[+] ASSERTION 1 PASSED: P_ship is a valid stochastic matrix.")
    print("[+] ASSERTION 2 PASSED: Constraint enforced to 1e-6 relative precision.")
    print("[+] ASSERTION 3 PASSED: Constraint non-trivially reshapes the matrix.")
    print("[+] ASSERTION 4 PASSED: Minimum-KL theorem holds empirically (0 / 30 below).")
    print("[+] ASSERTION 5 PASSED: Pre-renorm row sums to 1 within 1e-10.")
    print("[+] ASSERTION 6 PASSED: Perron-Frobenius applies, spectral gap clean.")
    print("\n[+] BIOLOGICAL CONCLUSION: Pressé-Ghosh-Lee-Dill 2013 is implemented")
    print("    correctly. The organism's trajectory inference engine produces the")
    print("    MAXIMUM-CALIBER (minimum-relative-entropy) Markov chain consistent")
    print("    with the dynamic flux constraint. Path-entropy planning is real.")
    print("[+] EVENT 18 PEER REVIEW PASSED.")
    return True


if __name__ == "__main__":
    proof_of_property()
