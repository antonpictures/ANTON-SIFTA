import numpy as np
from itertools import product


# ──────────────────────────────────────────────────────────────────────
#  QUASISPECIES  —  selection-mutation steady state on {0,1}^L
# ──────────────────────────────────────────────────────────────────────


class Quasispecies:
    """
    Eigen's quasispecies model on the full genotype space {0,1}^L
    with single-peak fitness landscape:

        fitness(σ*) = sigma > 1   (master sequence)
        fitness(σ)  = 1           (everyone else)

    Per-site mutation rate q. Steady state = Perron eigenvector of
    the mutation-selection matrix M = Q · diag(W).

    For L up to ~14 we can hold the full 2^L matrix in memory. That
    is enough to see the error threshold cleanly.
    """

    def __init__(self, L: int = 10, sigma: float = 4.0,
                 master_index: int = 0):
        if L > 16:
            raise ValueError("L too large for dense quasispecies; use sparse model.")
        self.L = L
        self.S = 1 << L  # 2^L genotypes
        self.sigma = sigma
        self.master = master_index
        self.W = np.ones(self.S)
        self.W[self.master] = sigma
        self._hamming = self._build_hamming_table()

    def _build_hamming_table(self) -> np.ndarray:
        """Hamming distance table. O(2^(2L)). Fine for L<=12."""
        bits = np.array([
            [(i >> k) & 1 for k in range(self.L)] for i in range(self.S)
        ], dtype=np.int8)
        # Pairwise XOR popcount via broadcasting
        diff = bits[:, None, :] ^ bits[None, :, :]
        return diff.sum(axis=-1)

    def mutation_matrix(self, q: float) -> np.ndarray:
        """Q[i,j] = prob genotype j mutates to i in one replication."""
        d = self._hamming
        return (q ** d) * ((1.0 - q) ** (self.L - d))

    def steady_state(self, q: float) -> np.ndarray:
        """Perron eigenvector of Q·diag(W). L1-normalized."""
        Q = self.mutation_matrix(q)
        M = Q * self.W[None, :]  # column-scale by fitness
        # Power iteration (M has positive entries -> Perron-Frobenius)
        v = np.full(self.S, 1.0 / self.S)
        for _ in range(2000):
            v = M @ v
            n = v.sum()
            if n <= 0:
                break
            v = v / n
        return v

    def master_fraction(self, q: float) -> float:
        """Steady-state frequency of the master sequence."""
        return float(self.steady_state(q)[self.master])


