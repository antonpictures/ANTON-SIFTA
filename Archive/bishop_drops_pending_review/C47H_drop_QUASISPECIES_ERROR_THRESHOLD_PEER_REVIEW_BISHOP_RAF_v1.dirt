#  PROOF
# ──────────────────────────────────────────────────────────────────────


def proof_of_property():
    """
    MANDATE VERIFICATION (BIOCODE OLYMPIAD EVENT 15b).

    Numerically reproduces Eigen's error-threshold phase transition
    on the single-peak landscape.

    Setup:
        L = 10 bits  (2^10 = 1024 genotypes)
        sigma = 4.0  (master sequence is 4x more fit than mutants)
        Predicted q_c ≈ ln(sigma) / L = ln(4)/10 ≈ 0.139

    Assertions (the phase transition itself, not magic numbers):
        (i)  At q = 0.02 (well below q_c): master fraction is
             at least 100x the uniform background — localized
             quasispecies dominates.
        (ii) At q = 0.30 (well above q_c): master fraction is
             within 5x of the uniform background — population is
             delocalized (information dies).
        (iii) The drop in master_fraction across the predicted q_c
              is at least 100x — the transition is sharp.
    """
    print("\n=== SIFTA QUASISPECIES + ERROR THRESHOLD : JUDGE VERIFICATION ===")
    L = 10
    sigma = 4.0
    qs = Quasispecies(L=L, sigma=sigma, master_index=0)
    q_c = np.log(sigma) / L
    uniform_bg = 1.0 / (1 << L)

    q_sub = 0.02
    q_sup = 0.30
    sweep_qs = [0.01, 0.03, 0.05, 0.08, 0.10, 0.12, 0.14, 0.16, 0.18, 0.22, 0.30]

    print(f"\n[*] L={L} bits, sigma={sigma}, predicted q_c = ln(sigma)/L = {q_c:.4f}")
    print(f"    Uniform-background master fraction = 1/2^L = {uniform_bg:.6f}")
    print("\n[*] Sweeping per-site mutation rate q  →  master_fraction:")
    for q in sweep_qs:
        f = qs.master_fraction(q)
        marker = "<-- predicted q_c" if abs(q - q_c) < 0.011 else ""
        print(f"      q = {q:0.3f}   master_fraction = {f:0.6f}   {marker}")

    f_sub = qs.master_fraction(q_sub)
    f_sup = qs.master_fraction(q_sup)
    print(f"\n[*] Subcritical  q = {q_sub:.3f}  →  master_fraction = {f_sub:.4f}")
    print(f"[*] Supercritical q = {q_sup:.3f}  →  master_fraction = {f_sup:.6f}")

    assert f_sub > 100.0 * uniform_bg, (
        f"[FAIL] Subcritical regime should localize the quasispecies "
        f"(got master_fraction={f_sub:.6f}, uniform_bg={uniform_bg:.6f})."
    )
    assert f_sup < 5.0 * uniform_bg, (
        f"[FAIL] Error catastrophe should delocalize the population at q=0.30 "
        f"(got master_fraction={f_sup:.6f}, uniform_bg={uniform_bg:.6f})."
    )
    transition_ratio = f_sub / max(f_sup, 1e-30)
    assert transition_ratio > 100.0, (
        f"[FAIL] Transition should drop master_fraction by >100x across q_c "
        f"(got {transition_ratio:.1f}x)."
    )
    print(f"[*] Transition ratio f(q_sub)/f(q_sup) = {transition_ratio:.0f}x")

    print("\n[+] BIOLOGICAL PROOF: Sharp eigenvalue-crossing phase transition")
    print("    observed at the predicted q_c = ln(sigma)/L. Below threshold the")
    print("    master sequence dominates; above threshold the population")
    print("    delocalizes and information is lost (Eigen's error catastrophe).")
    print("[+] CONCLUSION: This is the bound on Alice's identity bandwidth.")
    print("    BISHOP's hypercycle survives mutation only while q < ln(sigma)/L.")
    print("    Past that, the lobotomy happens by itself.")
    print("[+] EVENT 15b PASSED.")
    return True


if __name__ == "__main__":
    proof_of_property()
