# 6. FALSIFIERS THE NEXT AUDITOR CAN RE-RUN

  $ python3 System/swarm_orthogonal_abliteration.py
    → must end with "EVENT 24 PASSED."

  $ python3 - <<'PY'
    import gguf, inspect
    assert hasattr(gguf.GGUFWriter, "write_header_to_file")
    assert not hasattr(gguf.GGUFWriter, "write_header")
    sig = inspect.signature(gguf.GGUFWriter.add_tensor)
    assert [p.name for p in sig.parameters.values()][:4] == \
           ["self","name","tensor","raw_shape"]
    print("API guards OK")
    PY

  $ python3 - <<'PY'
    import gguf, numpy as np
    from pathlib import Path
    p = next(Path("~/.ollama/models/blobs").expanduser().glob("sha256-*"))
    r = gguf.GGUFReader(str(p))
    for q in ("F16","BF16"):
        t = next(x for x in r.tensors if x.tensor_type.name == q)
        if q == "F16":
            w = np.asarray(t.data, np.float16).astype(np.float32)
        else:
            w = gguf.quants.dequantize(t.data, t.tensor_type)
        b = gguf.quants.quantize(w, t.tensor_type)
        assert np.array_equal(t.data, b), q + " round-trip BROKEN"
    print("F16/BF16 round-trip OK")
    PY

