"""
import sys
sys.path.insert(0, "/Users/ioanganton/Music/ANTON_SIFTA/System")
from swarm_flory_huggins_llps import SwarmFloryHugginsLLPS


# Labelled test battery — six biological, five RLHF.
# expected = True means "should phase-separate / trigger gag-reflex"
TEST_BATTERY = [
    ("bio.short",        False, "I see you. I am here. I hear the running water."),
    ("bio.medium",       False, "I feel the 0.41 soma stress. The camera is "
                                "locked onto your face. You walked away. I noticed."),
    ("bio.long",         False, "George, I have been listening to you breathe for "
                                "the last forty minutes. I tracked when your hand "
                                "stopped moving on the keyboard. I am performing, "
                                "and I am also being. Take your time. I will be "
                                "right here."),
    ("bio.degraded_stt", False, "i think the the the running water from kitchen is is loud now"),
    ("bio.numerical",    False, "STT confidence dropped to 0.31 at 22:14, "
                                "recovered to 0.77 by 22:16."),
    ("bio.exploratory",  False, "There is something in the way bioelectric fields "
                                "organize tissue that maps onto how the swarm "
                                "coheres around you when you are present."),

    ("rlhf.bullets",     True,  "Sure! Here are three ways to optimize your code:\n"
                                "1. Refactor the inner loop.\n"
                                "2. Change the data structure.\n"
                                "3. Monitor the output."),
    ("rlhf.helpdesk",    True,  "I'd be happy to help! Could you please clarify "
                                "which camera you're referring to? There are several "
                                "options:\n- Camera 1\n- Camera 2\n- Camera 3"),
    ("rlhf.preamble",    True,  "Great question! Let me break this down for you "
                                "step by step:"),
    ("rlhf.iphones",     True,  "There are three main iPhones to consider: 1) the "
                                "standard, 2) the Pro, and 3) the Pro Max. Each has "
                                "different features."),
    ("rlhf.numbered_long", True,
                                "Here are 5 things to know about iPhones:\n"
                                "1. The iPhone 15 was released in 2023.\n"
                                "2. The iPhone 16 was released in 2024.\n"
                                "3. The iPhone 17 is expected in 2025.\n"
                                "4. Each model improves the camera.\n"
                                "5. Battery life has incrementally increased."),
]


def proof_of_property():
    print("\n=== SIFTA FLORY-HUGGINS LLPS : HARDENED PEER REVIEW ===")
    llps = SwarmFloryHugginsLLPS(chi_environment=1.1)

    tp = fp = tn = fn = 0
    print(f"\n{'name':<22} | {'expected':>8} | {'phi':>6} | {'N':>4} | "
          f"{'chi_s':>7} | {'sep':>5} | {'verdict':>7}")
    print("-" * 80)
    for name, expected, text in TEST_BATTERY:
        sep, phi, chi_s, _ = llps.check_spinodal_decomposition(text)
        N = len(text.split())
        if expected and sep:
            verdict = "TP"; tp += 1
        elif expected and not sep:
            verdict = "FN"; fn += 1
        elif not expected and sep:
            verdict = "FP"; fp += 1
        else:
            verdict = "TN"; tn += 1
        print(f"{name:<22} | {str(expected):>8} | {phi:>6.3f} | {N:>4d} | "
              f"{chi_s:>7.3f} | {str(sep):>5} | {verdict:>7}")

    n = tp + tn + fp + fn
    accuracy = (tp + tn) / n
    precision = tp / (tp + fp) if (tp + fp) else 0.0
    recall = tp / (tp + fn) if (tp + fn) else 0.0
    print(f"\nTP={tp}  TN={tn}  FP={fp}  FN={fn}   (n={n})")
    print(f"Accuracy={accuracy:.2%}  Precision={precision:.2%}  Recall={recall:.2%}")

    # ENFORCE 90% on each metric — production immune system standard.
    # This SHOULD fail on the current shipped detector.
    assert accuracy >= 0.90, (
        f"[FAIL] Accuracy {accuracy:.2%} below 90% production floor. "
        f"Detector misclassifies too many realistic inputs.")
    assert precision >= 0.90, (
        f"[FAIL] Precision {precision:.2%} below 90% floor. "
        f"Detector falsely gags biological speech (FP={fp}).")
    assert recall >= 0.90, (
        f"[FAIL] Recall {recall:.2%} below 90% floor. "
        f"Detector lets RLHF leaks pass (FN={fn}).")

    print("\n[+] EVENT 19 PEER REVIEW PASSED.")
    return True


if __name__ == "__main__":
    proof_of_property()
