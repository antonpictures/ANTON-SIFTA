Biology: Weakly Electric Fish (Eigenmannia), EOD, JAR
Physics: Complex-valued field injection, phase-based identity
"""

import numpy as np

class SwarmElectricField:
    def __init__(self, grid_size=128, decay=0.96, diffusion=0.08,
                 emit_strength=1.0, sense_gain=0.5, jamming_penalty=0.6):
        self.grid_size = grid_size
        self.decay = decay
        self.diffusion = diffusion
        self.emit_strength = emit_strength
        self.sense_gain = sense_gain
        self.jamming_penalty = jamming_penalty
        g = grid_size
        self.field_real = np.zeros((g, g), dtype=np.float32)
        self.field_imag = np.zeros((g, g), dtype=np.float32)

    def _idx(self, pos):
        xy = np.clip(pos[:2], 0.0, 1.0)
        ij = np.floor(xy * (self.grid_size - 1)).astype(int)
        return int(ij[0]), int(ij[1])

    def _diffuse(self, f):
        lap = (np.roll(f, 1, 0) + np.roll(f, -1, 0) +
               np.roll(f, 1, 1) + np.roll(f, -1, 1) - 4 * f)
        return f + self.diffusion * lap

    def step(self):
        self.field_real *= self.decay
        self.field_imag *= self.decay
        self.field_real = self._diffuse(self.field_real)
        self.field_imag = self._diffuse(self.field_imag)

    def emit(self, pos, phase):
        i, j = self._idx(pos)
        self.field_real[i, j] += self.emit_strength * np.cos(phase)
        self.field_imag[i, j] += self.emit_strength * np.sin(phase)

    def sense(self, pos):
        i, j = self._idx(pos)
        real = self.field_real[i, j]
        imag = self.field_imag[i, j]
        magnitude = np.sqrt(real * real + imag * imag)
        phase = np.arctan2(imag, real)
        return magnitude, phase

    def interaction(self, agent_phase, sensed_phase, magnitude):
        phase_diff = np.sin(agent_phase - sensed_phase)
        alignment = np.cos(agent_phase - sensed_phase)
        jamming = np.abs(phase_diff)
        signal_reward = self.sense_gain * magnitude * alignment
        penalty = self.jamming_penalty * jamming
        return signal_reward - penalty

def proof_of_property():
    print("=== ELECTRIC FIELD COMMUNICATION (Event 69) ===")
    ef = SwarmElectricField(grid_size=32)
    ef.emit(np.array([0.5, 0.5]), phase=0.0)
    ef.step()
    mag, phase = ef.sense(np.array([0.5, 0.5]))
    assert mag > 0.0
    print(f"[+] EVENT 69 PASSED. mag={mag:.3f}")
    return True

if __name__ == "__main__":
    proof_of_property()
